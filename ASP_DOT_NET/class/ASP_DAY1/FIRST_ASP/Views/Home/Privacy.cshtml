@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-8">
            <h1 class="mb-4">Privacy Policy</h1>
            <p class="lead text-muted mb-5">
                Your privacy and data security are important to us.
            </p>

            <h4 class="mt-4">Information Collection</h4>
            <p>
                This Student Management System stores only the information required to manage student records, such as names, contact details, academic information, and related data.
            </p>

            <h4 class="mt-4">Data Usage</h4>
            <p>
                Student information is used solely for educational management purposes and is not shared with unauthorized third parties.
            </p>

            <h4 class="mt-4">Data Security</h4>
            <p>
                Appropriate measures are taken to protect stored data from unauthorized access, modification, or disclosure.
            </p>

            <h4 class="mt-4">System Usage</h4>
            <p>
                Users are responsible for maintaining the confidentiality of their accounts and using the application responsibly.
            </p>
            <div class="mt-5 pt-4 border-top text-muted small">
                <strong>Note:</strong> This application is developed for learning and demonstration purposes using ASP.NET Core MVC and SQL Server.
            </div>

        </div>
    </div>
</div>