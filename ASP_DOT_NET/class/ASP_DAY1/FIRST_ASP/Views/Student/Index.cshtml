@{
    ViewData["Title"] = "Students";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <div>
            <h1 class="h2 mb-1">Students</h1>
            <p class="text-muted mb-0">Manage student records and profiles.</p>
        </div>
        <div>
            <a asp-controller="Student" asp-action="StudentList" class="btn btn-primary">
                View Directory
            </a>
        </div>
    </div>

    <div class="bg-light p-4 rounded-3 border">
        <h5 class="mb-3">Student Operations</h5>
        <p class="text-muted mb-4">
            Access the directory to browse, register, update, or remove student records from the system.
        </p>
        <div class="d-flex gap-2">
            <a asp-controller="Student" asp-action="StudentList" class="btn btn-outline-primary">
                Browse Students
            </a>
            <a asp-controller="Student" asp-action="Create" class="btn btn-outline-secondary">
                Register New Student
            </a>
        </div>
    </div>

</div>